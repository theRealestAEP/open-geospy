# Minimal defaults for local dev.

# --- Postgres ---
POSTGRES_USER=geospy
POSTGRES_PASSWORD=geospy
POSTGRES_DB=geospy
POSTGRES_PORT=5432
DATABASE_URL=postgresql://geospy:geospy@127.0.0.1:5432/geospy

# --- Retrieval/Search ---
GEOSPY_VECTOR_BACKEND=postgres
GEOSPY_MAX_RETRIEVAL_UPLOAD_MB=15
GEOSPY_CLIP_MODEL_ENABLED=1
GEOSPY_CLIP_MODEL=ViT-B-32
GEOSPY_CLIP_PRETRAINED=laion2b_s34b_b79k
GEOSPY_CLIP_VERSION=open_clip

# Optional: local/cloud LanceDB vector backend (search-only mode)
# GEOSPY_VECTOR_BACKEND=lancedb
# GEOSPY_LANCEDB_URI=.lancedb
# GEOSPY_LANCEDB_TABLE=capture_embeddings
# GEOSPY_LANCEDB_VECTOR_COLUMN=embedding
# GEOSPY_LANCEDB_EMBEDDING_BASE_COLUMN=

# --- Embedding writes ---
GEOSPY_EMBED_ON_INGEST=1
GEOSPY_EMBED_BATCH_SIZE=128

# Optional: enable secondary model
# GEOSPY_PIGEON_MODEL_ENABLED=1
# GEOSPY_PIGEON_RUNTIME=open_clip
# GEOSPY_PIGEON_CLIP_MODEL=ViT-B-16
# GEOSPY_PIGEON_CLIP_PRETRAINED=laion2b_s34b_b88k
# GEOSPY_PIGEON_MODEL_VERSION=open_clip_place

# Optional: disable background auto indexing
# GEOSPY_AUTO_INDEX_ENABLED=0

# Optional: retrieval tuning overrides
# GEOSPY_RETRIEVAL_DILIGENT_MODE=1
# GEOSPY_RETRIEVAL_SEARCH_CANDIDATE_MULTIPLIER=10
# GEOSPY_RETRIEVAL_SEARCH_MAX_CANDIDATES=5000
# GEOSPY_RETRIEVAL_IVFFLAT_PROBES=120
